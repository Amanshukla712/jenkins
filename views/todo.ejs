<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Todo List</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet" />

    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --ink:     #1a1814;
        --ink-2:   #5a5650;
        --ink-3:   #9a9590;
        --paper:   #faf8f4;
        --cream:   #f0ece4;
        --line:    #e4dfd6;
        --green:   #2d6a4f;
        --green-l: #d8f3dc;
        --red:     #9b2335;
        --red-l:   #fce8eb;
        --amber:   #b45309;
        --amber-l: #fef3c7;
        --accent:  #3d5a80;
        --accent-l:#e8eef6;
        --radius:  14px;
      }

      body {
        font-family: 'DM Sans', sans-serif;
        background-color: var(--paper);
        color: var(--ink);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 0 1rem 4rem;
      }

      header {
        width: 100%;
        max-width: 640px;
        padding: 3.5rem 0 2rem;
      }

      .eyebrow {
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--ink-3);
        display: block;
        margin-bottom: 4px;
      }

      h1 {
        font-family: 'DM Serif Display', Georgia, serif;
        font-size: clamp(2rem, 6vw, 2.8rem);
        font-weight: 400;
        line-height: 1.1;
        color: var(--ink);
        margin-bottom: 1.25rem;
      }

      h1 em { font-style: italic; color: var(--accent); }

      .header-rule {
        height: 1px;
        background: linear-gradient(to right, var(--line), transparent);
      }

      .stats {
        width: 100%;
        max-width: 640px;
        display: flex;
        gap: 10px;
        margin-bottom: 1.5rem;
        align-items: center;
      }

      .stat-pill {
        font-size: 12px;
        font-weight: 500;
        padding: 5px 12px;
        border-radius: 99px;
        display: inline-flex;
        align-items: center;
        gap: 5px;
      }

      .stat-pill.total { background: var(--accent-l); color: var(--accent); }
      .stat-pill.live  { background: var(--green-l);  color: var(--green); }

      /* live dot pulse */
      .live-dot {
        width: 7px; height: 7px;
        border-radius: 50%;
        background: var(--green);
        animation: pulse 2s infinite;
        display: inline-block;
      }

      @keyframes pulse {
        0%, 100% { opacity: 1; }
        50%       { opacity: 0.3; }
      }

      .todo-list {
        width: 100%;
        max-width: 640px;
        display: flex;
        flex-direction: column;
        gap: 8px;
        list-style: none;
        margin-bottom: 2rem;
      }

      .todo-item {
        background: #fff;
        border: 1px solid var(--line);
        border-radius: var(--radius);
        padding: 1rem 1.1rem;
        display: flex;
        align-items: center;
        gap: 12px;
        box-shadow: 0 1px 4px rgba(26,24,20,.05);
        transition: box-shadow .18s, border-color .18s, transform .15s;
        position: relative;
        overflow: hidden;
      }

      .todo-item::before {
        content: '';
        position: absolute;
        left: 0; top: 0; bottom: 0;
        width: 3px;
        background: var(--accent);
        border-radius: 3px 0 0 3px;
        opacity: 0;
        transition: opacity .18s;
      }

      .todo-item:hover { box-shadow: 0 2px 12px rgba(26,24,20,.1); border-color: #ccc; transform: translateY(-1px); }
      .todo-item:hover::before { opacity: 1; }
      .todo-item:hover .todo-actions { opacity: 1; }

      /* flash animation for newly added items */
      @keyframes flashIn {
        0%   { background: var(--accent-l); transform: translateY(-4px); opacity: 0; }
        100% { background: #fff;            transform: translateY(0);     opacity: 1; }
      }

      .todo-item.new { animation: flashIn 0.5s ease forwards; }

      .todo-number {
        flex-shrink: 0;
        width: 26px; height: 26px;
        border-radius: 50%;
        background: var(--cream);
        border: 1px solid var(--line);
        display: flex; align-items: center; justify-content: center;
        font-size: 11px; font-weight: 500; color: var(--ink-3);
      }

      .todo-text { flex: 1; font-size: 15px; color: var(--ink); line-height: 1.45; }

      .todo-actions {
        display: flex; gap: 4px; flex-shrink: 0;
        opacity: 0.4; transition: opacity .18s;
      }

      .action-btn {
        display: inline-flex; align-items: center; justify-content: center;
        width: 32px; height: 32px;
        border-radius: 8px;
        text-decoration: none;
        font-size: 15px;
        border: 1px solid transparent;
        transition: background .15s, border-color .15s;
      }

      .action-btn.edit   { color: var(--amber); }
      .action-btn.edit:hover   { background: var(--amber-l); border-color: #f5d88a; }
      .action-btn.delete { color: var(--red); }
      .action-btn.delete:hover { background: var(--red-l);   border-color: #f5b8c0; }

      .empty-state {
        width: 100%; max-width: 640px;
        text-align: center;
        padding: 3rem 1.5rem;
        color: var(--ink-3);
        border: 1.5px dashed var(--line);
        border-radius: var(--radius);
        margin-bottom: 2rem;
      }

      .empty-state p { font-size: 14px; font-style: italic; }

      .form-card {
        width: 100%; max-width: 640px;
        background: #fff;
        border: 1px solid var(--line);
        border-radius: var(--radius);
        padding: 1.5rem;
        box-shadow: 0 1px 4px rgba(26,24,20,.05);
      }

      .form-label {
        display: block;
        font-size: 11px; font-weight: 500;
        letter-spacing: .1em; text-transform: uppercase;
        color: var(--ink-3); margin-bottom: 10px;
      }

      .form-row { display: flex; gap: 8px; }

      .form-input {
        flex: 1; height: 44px; padding: 0 14px;
        border: 1.5px solid var(--line); border-radius: 10px;
        font-family: 'DM Sans', sans-serif; font-size: 15px;
        color: var(--ink); background: var(--paper); outline: none;
        transition: border-color .18s, background .18s;
      }

      .form-input::placeholder { color: var(--ink-3); }
      .form-input:focus { border-color: var(--accent); background: #fff; box-shadow: 0 0 0 3px var(--accent-l); }

      .form-submit {
        height: 44px; padding: 0 20px;
        background: var(--ink); color: #fff;
        border: none; border-radius: 10px;
        font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 500;
        cursor: pointer; transition: background .15s, transform .12s;
        white-space: nowrap;
      }

      .form-submit:hover  { background: #2e2b26; }
      .form-submit:active { transform: scale(0.97); }

      @media (max-width: 480px) {
        header { padding: 2.5rem 0 1.5rem; }
        .form-row { flex-direction: column; }
        .form-submit { width: 100%; }
        .todo-actions { opacity: 1; }
      }
    </style>
  </head>
  <body>

    <header>
      <span class="eyebrow">My workspace</span>
      <h1>What needs to get <em>done?</em></h1>
      <div class="header-rule"></div>
    </header>

    <div class="stats">
      <span class="stat-pill total" id="task-count">
        &#10064; <%= todolist.length %> task<%= todolist.length !== 1 ? 's' : '' %>
      </span>
      <span class="stat-pill live" id="live-badge" style="display:none;">
        <span class="live-dot"></span> Live
      </span>
    </div>

    <% if (todolist.length === 0) { %>
    <div class="empty-state" id="empty-state">
      <p>No tasks yet — you're all clear!</p>
    </div>
    <% } %>

    <ul class="todo-list" id="todo-list">
      <% todolist.forEach(function(todo, index) { %>
      <li class="todo-item">
        <span class="todo-number"><%= index + 1 %></span>
        <span class="todo-text"><%- todo %></span>
        <div class="todo-actions">
          <a href="/todo/<%= index %>" class="action-btn edit" title="Edit task">&#9998;</a>
          <a href="/todo/delete/<%= index %>" class="action-btn delete" title="Delete task">&#10005;</a>
        </div>
      </li>
      <% }); %>
    </ul>

    <div class="form-card">
      <label class="form-label" for="newtodo">Add a new task</label>
      <form action="/todo/add/" method="post">
        <div class="form-row">
          <input
            class="form-input"
            type="text"
            name="newtodo"
            id="newtodo"
            placeholder="What should you do next?"
            autofocus
          />
          <button class="form-submit" type="submit">+ Add</button>
        </div>
      </form>
    </div>

    <!-- ── SSE client ───────────────────────────────────────────── -->
    <script>
      const taskCountEl  = document.getElementById('task-count');
      const liveBadgeEl  = document.getElementById('live-badge');
      const emptyStateEl = document.getElementById('empty-state');
      const todoListEl   = document.getElementById('todo-list');

      // ── helpers ──────────────────────────────────────────────────

      function updateCountPill(n) {
        taskCountEl.textContent = `❖ ${n} task${n !== 1 ? 's' : ''}`;
      }

      function buildItem(todo, index, isNew) {
        const li = document.createElement('li');
        li.className = 'todo-item' + (isNew ? ' new' : '');
        li.innerHTML = `
          <span class="todo-number">${index + 1}</span>
          <span class="todo-text">${todo}</span>
          <div class="todo-actions">
            <a href="/todo/${index}" class="action-btn edit" title="Edit task">✎</a>
            <a href="/todo/delete/${index}" class="action-btn delete" title="Delete task">✕</a>
          </div>`;
        return li;
      }

      // Full re-render of the list from the server's current array
      // Used after delete / edit so indices are always correct
      function syncList(list) {
        todoListEl.innerHTML = '';
        list.forEach((todo, index) => {
          todoListEl.appendChild(buildItem(todo, index, false));
        });
        updateCountPill(list.length);
        if (emptyStateEl) emptyStateEl.style.display = list.length ? 'none' : '';
      }

      // ── SSE connection ───────────────────────────────────────────

      const evtSource = new EventSource('/events');

      evtSource.onopen = () => {
        liveBadgeEl.style.display = '';   // show green "Live" badge
      };

      evtSource.onmessage = (e) => {
        const data = JSON.parse(e.data);

        if (data.type === 'add') {
          // Append only the new item — avoids full re-render flash
          if (emptyStateEl) emptyStateEl.style.display = 'none';
          const li = buildItem(data.todo, data.list.length - 1, true);
          todoListEl.appendChild(li);
          updateCountPill(data.list.length);

        } else if (data.type === 'sync') {
          // Delete or edit happened — re-render so links/numbers stay correct
          syncList(data.list);
        }
      };

      evtSource.onerror = () => {
        liveBadgeEl.style.display = 'none';  // hide badge when disconnected
        // EventSource auto-reconnects — no manual retry needed
      };
    </script>
    <!-- ─────────────────────────────────────────────────────────── -->

  </body>
</html>
