<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Todo List</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet" />

    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --ink:     #1a1814;
        --ink-2:   #5a5650;
        --ink-3:   #9a9590;
        --paper:   #faf8f4;
        --cream:   #f0ece4;
        --line:    #e4dfd6;
        --green:   #2d6a4f;
        --green-l: #d8f3dc;
        --red:     #9b2335;
        --red-l:   #fce8eb;
        --amber:   #b45309;
        --amber-l: #fef3c7;
        --accent:  #3d5a80;
        --accent-l:#e8eef6;
        --radius:  14px;
        --shadow:  0 2px 12px rgba(26,24,20,0.08);
        --shadow-l:0 1px 4px  rgba(26,24,20,0.05);
      }

      body {
        font-family: 'DM Sans', sans-serif;
        background-color: var(--paper);
        color: var(--ink);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 0 1rem 4rem;
      }

      /* ── Header ──────────────────────────────────────── */
      header {
        width: 100%;
        max-width: 640px;
        padding: 3.5rem 0 2rem;
        display: flex;
        flex-direction: column;
        gap: 4px;
      }

      .eyebrow {
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--ink-3);
      }

      h1 {
        font-family: 'DM Serif Display', Georgia, serif;
        font-size: clamp(2rem, 6vw, 2.8rem);
        font-weight: 400;
        line-height: 1.1;
        color: var(--ink);
      }

      h1 em {
        font-style: italic;
        color: var(--accent);
      }

      .header-rule {
        margin-top: 1.25rem;
        height: 1px;
        background: linear-gradient(to right, var(--line), transparent);
      }

      /* ── Stats bar ───────────────────────────────────── */
      .stats {
        width: 100%;
        max-width: 640px;
        display: flex;
        gap: 10px;
        margin-bottom: 1.5rem;
      }

      .stat-pill {
        font-size: 12px;
        font-weight: 500;
        padding: 5px 12px;
        border-radius: 99px;
        display: inline-flex;
        align-items: center;
        gap: 5px;
      }

      .stat-pill.total  { background: var(--accent-l); color: var(--accent); }
      .stat-pill.done   { background: var(--green-l);  color: var(--green);  }

      /* ── Todo list ───────────────────────────────────── */
      .todo-list {
        width: 100%;
        max-width: 640px;
        display: flex;
        flex-direction: column;
        gap: 8px;
        list-style: none;
        margin-bottom: 2rem;
      }

      .todo-item {
        background: #fff;
        border: 1px solid var(--line);
        border-radius: var(--radius);
        padding: 1rem 1.1rem;
        display: flex;
        align-items: center;
        gap: 12px;
        box-shadow: var(--shadow-l);
        transition: box-shadow 0.18s, border-color 0.18s, transform 0.15s;
        position: relative;
        overflow: hidden;
      }

      .todo-item::before {
        content: '';
        position: absolute;
        left: 0; top: 0; bottom: 0;
        width: 3px;
        background: var(--accent);
        border-radius: 3px 0 0 3px;
        opacity: 0;
        transition: opacity 0.18s;
      }

      .todo-item:hover {
        box-shadow: var(--shadow);
        border-color: #ccc;
        transform: translateY(-1px);
      }

      .todo-item:hover::before { opacity: 1; }

      .todo-number {
        flex-shrink: 0;
        width: 26px;
        height: 26px;
        border-radius: 50%;
        background: var(--cream);
        border: 1px solid var(--line);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 500;
        color: var(--ink-3);
      }

      .todo-text {
        flex: 1;
        font-size: 15px;
        font-weight: 400;
        color: var(--ink);
        line-height: 1.45;
      }

      .todo-actions {
        display: flex;
        gap: 4px;
        flex-shrink: 0;
        opacity: 0.4;
        transition: opacity 0.18s;
      }

      .todo-item:hover .todo-actions { opacity: 1; }

      .action-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        text-decoration: none;
        font-size: 15px;
        border: 1px solid transparent;
        transition: background 0.15s, border-color 0.15s;
      }

      .action-btn.edit {
        color: var(--amber);
      }
      .action-btn.edit:hover {
        background: var(--amber-l);
        border-color: #f5d88a;
      }

      .action-btn.delete {
        color: var(--red);
      }
      .action-btn.delete:hover {
        background: var(--red-l);
        border-color: #f5b8c0;
      }

      /* ── Empty state ─────────────────────────────────── */
      .empty-state {
        width: 100%;
        max-width: 640px;
        text-align: center;
        padding: 3rem 1.5rem;
        color: var(--ink-3);
        border: 1.5px dashed var(--line);
        border-radius: var(--radius);
        margin-bottom: 2rem;
      }

      .empty-state .empty-icon {
        font-size: 2rem;
        margin-bottom: 0.75rem;
        display: block;
        opacity: 0.5;
      }

      .empty-state p {
        font-size: 14px;
        font-style: italic;
      }

      /* ── Add form ────────────────────────────────────── */
      .form-card {
        width: 100%;
        max-width: 640px;
        background: #fff;
        border: 1px solid var(--line);
        border-radius: var(--radius);
        padding: 1.5rem;
        box-shadow: var(--shadow-l);
      }

      .form-label {
        display: block;
        font-size: 12px;
        font-weight: 500;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--ink-3);
        margin-bottom: 10px;
      }

      .form-row {
        display: flex;
        gap: 8px;
      }

      .form-input {
        flex: 1;
        height: 44px;
        padding: 0 14px;
        border: 1.5px solid var(--line);
        border-radius: 10px;
        font-family: 'DM Sans', sans-serif;
        font-size: 15px;
        color: var(--ink);
        background: var(--paper);
        outline: none;
        transition: border-color 0.18s, background 0.18s;
      }

      .form-input::placeholder { color: var(--ink-3); }

      .form-input:focus {
        border-color: var(--accent);
        background: #fff;
        box-shadow: 0 0 0 3px var(--accent-l);
      }

      .form-submit {
        height: 44px;
        padding: 0 20px;
        background: var(--ink);
        color: #fff;
        border: none;
        border-radius: 10px;
        font-family: 'DM Sans', sans-serif;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        transition: background 0.15s, transform 0.12s;
        white-space: nowrap;
        letter-spacing: 0.02em;
      }

      .form-submit:hover  { background: #2e2b26; }
      .form-submit:active { transform: scale(0.97); }

      /* ── Responsive ──────────────────────────────────── */
      @media (max-width: 480px) {
        header { padding: 2.5rem 0 1.5rem; }
        .form-row { flex-direction: column; }
        .form-submit { width: 100%; }
        .todo-actions { opacity: 1; }
      }
    </style>
  </head>
  <body>

    <header>
      <span class="eyebrow">My workspace</span>
      <h1>What needs to get <em>done?</em></h1>
      <div class="header-rule"></div>
    </header>

    <div class="stats">
      <span class="stat-pill total">
        &#10064; <%= todolist.length %> task<%= todolist.length !== 1 ? 's' : '' %>
      </span>
      <% if (todolist.length > 0) { %>
      <span class="stat-pill done">&#10003; In progress</span>
      <% } %>
    </div>

    <% if (todolist.length === 0) { %>
    <div class="empty-state">
      <span class="empty-icon">&#9744;</span>
      <p>No tasks yet — you're all clear!</p>
    </div>
    <% } else { %>
    <ul class="todo-list">
      <% todolist.forEach(function(todo, index) { %>
      <li class="todo-item">
        <span class="todo-number"><%= index + 1 %></span>
        <span class="todo-text"><%- todo %></span>
        <div class="todo-actions">
          <a href="/todo/<%= index %>" class="action-btn edit" title="Edit task">&#9998;</a>
          <a href="/todo/delete/<%= index %>" class="action-btn delete" title="Delete task">&#10005;</a>
        </div>
      </li>
      <% }); %>
    </ul>
    <% } %>

    <div class="form-card">
      <label class="form-label" for="newtodo">Add a new task</label>
      <form action="/todo/add/" method="post">
        <div class="form-row">
          <input
            class="form-input"
            type="text"
            name="newtodo"
            id="newtodo"
            placeholder="What should you do next?"
            autofocus
          />
          <button class="form-submit" type="submit">+ Add</button>
        </div>
      </form>
    </div>

  </body>
</html>
